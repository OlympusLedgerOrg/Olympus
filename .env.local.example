# Native Windows development environment.
# Copy to .env.local with:
#   Copy-Item .env.local.example .env.local

OLYMPUS_ENV=development
OLYMPUS_DEV_SIGNING_KEY=false
# setup-windows.ps1 generates a stable local 32-byte Ed25519 seed here when missing.
OLYMPUS_INGEST_SIGNING_KEY=
OLYMPUS_ALLOW_PUBLIC_WRITE_REGISTRATION=1

POSTGRES_USER=olympus
POSTGRES_PASSWORD=olympus
POSTGRES_DB=olympus

DATABASE_HOST=127.0.0.1
DATABASE_NAME=olympus
DATABASE_USER=olympus
DATABASE_PASSWORD=olympus
DATABASE_URL=postgresql+asyncpg://olympus:olympus@127.0.0.1:5432/olympus
PSYCOPG_URL=postgresql://olympus:olympus@127.0.0.1:5432/olympus
TEST_DATABASE_URL=postgresql://olympus:olympus@127.0.0.1:5432/olympus

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

OLYMPUS_USE_GO_SEQUENCER=false
OLYMPUS_SEQUENCER_URL=http://localhost:8081
OLYMPUS_REKOR_ENABLED=false
OLYMPUS_GUARDIAN_ENABLED=false

LOG_LEVEL=INFO
OLYMPUS_LOG_FORMAT=text
