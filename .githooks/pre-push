#!/usr/bin/env bash
# pre-push hook — mirrors the full per-PR CI gate locally.
# Activate by running:  bash scripts/install-hooks.sh
#
# Runs the same checks GitHub Actions runs on every PR:
#   - cargo fmt --check     (workspace)
#   - cargo clippy          (workspace, -D warnings)
#   - cargo test            (workspace)
#   - frontend tsc --noEmit + eslint
#   - frontend build
#
# Set OLYMPUS_SKIP_PREPUSH=1 to bypass (emergency only — CI will still gate the PR).

set -euo pipefail

if [ "${OLYMPUS_SKIP_PREPUSH:-0}" = "1" ]; then
    echo "[pre-push] OLYMPUS_SKIP_PREPUSH=1 — skipping local CI gate."
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
step() { echo -e "\n${BOLD}▸ $1${RESET}"; }

echo -e "\n${BOLD}Olympus pre-push CI gate${RESET}"
echo "────────────────────────────────────"

FAILED=()

run_check() {
    local name="$1"
    shift
    step "$name"
    if "$@"; then
        pass "$name"
    else
        fail "$name"
        FAILED+=("$name")
    fi
}

run_check "cargo fmt --check (workspace)" \
    cargo fmt --all -- --check

run_check "cargo clippy --workspace -- -D warnings" \
    cargo clippy --workspace --all-targets --quiet -- -D warnings

run_check "cargo test --workspace" \
    cargo test --workspace --quiet

run_check "frontend tsc --noEmit" \
    bash -c 'cd app/public-ui && pnpm exec tsc --noEmit'

run_check "frontend eslint" \
    bash -c 'cd app/public-ui && pnpm lint'

run_check "frontend build (vite)" \
    bash -c 'pnpm --filter app/public-ui build'

echo ""
echo "────────────────────────────────────"

if [ ${#FAILED[@]} -gt 0 ]; then
    echo -e "${RED}${BOLD}Pre-push gate failed:${RESET}"
    for f in "${FAILED[@]}"; do
        echo -e "  ${RED}✗${RESET} $f"
    done
    echo ""
    echo -e "${YELLOW}Fix the above, or bypass with:${RESET}"
    echo -e "  OLYMPUS_SKIP_PREPUSH=1 git push"
    echo ""
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — pushing.${RESET}\n"
exit 0
