#!/usr/bin/env bash
# pre-push hook — mirrors the CI quality gate locally.
# Install once with:  make install-hooks
#
# Runs the fast subset of CI checks before every push:
#   boundary-check · ruff lint · ruff format · mypy · bandit · unit tests
#
# Postgres integration tests are skipped here (they need a live DB).
# Run `make check` to execute the full gate including postgres.
#
# Set OLYMPUS_SKIP_PREPUSH=1 to bypass (emergency only).

set -euo pipefail

if [ "${OLYMPUS_SKIP_PREPUSH:-0}" = "1" ]; then
    echo "[pre-push] OLYMPUS_SKIP_PREPUSH=1 — skipping local CI gate."
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
step() { echo -e "\n${BOLD}▸ $1${RESET}"; }

echo -e "\n${BOLD}Olympus pre-push CI gate${RESET}"
echo "────────────────────────────────────"

FAILED=()

run_check() {
    local name="$1"
    shift
    step "$name"
    if "$@"; then
        pass "$name"
    else
        fail "$name"
        FAILED+=("$name")
    fi
}

run_check "Import boundaries" \
    python tools/check_import_boundaries.py

run_check "Demo key check" \
    bash -c '! grep -r --include="*.yml" --include="*.yaml" \
        -e "demo-key" \
        -e "84d53ce2f18ae4856edfe631810f984b8c78bf3c0e136bac89e45642c5c85b37" \
        -e "a665a45920422f9d417e4867efdc4fb8a04a1f3fff1fa07e998e86f7f7a27ae3" \
        . 2>/dev/null'

run_check "JSON schema validation" \
    python tools/validate_schemas.py

run_check "Ruff lint" \
    ruff check protocol/ storage/ api/ tests/ --output-format=concise

run_check "Ruff format" \
    ruff format --check protocol/ storage/ api/ tests/

run_check "Bandit security scan" \
    bandit -r protocol/ storage/ api/ -f txt -q

run_check "MyPy type check" \
    mypy protocol/ storage/ api/ --no-error-summary

run_check "Unit tests (no postgres)" \
    pytest tests/ -q --tb=short \
        -m "not postgres and not differential" \
        --no-header \
        --cov=protocol --cov=storage --cov=api \
        --cov-fail-under=85 \
        --cov-report=term-missing:skip-covered

echo ""
echo "────────────────────────────────────"

if [ ${#FAILED[@]} -gt 0 ]; then
    echo -e "${RED}${BOLD}Pre-push gate failed:${RESET}"
    for f in "${FAILED[@]}"; do
        echo -e "  ${RED}✗${RESET} $f"
    done
    echo ""
    echo -e "${YELLOW}Fix the above issues, or bypass with:${RESET}"
    echo -e "  OLYMPUS_SKIP_PREPUSH=1 git push"
    echo ""
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — pushing.${RESET}\n"
exit 0
