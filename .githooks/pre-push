#!/usr/bin/env bash
# pre-push hook — mirrors the full per-PR CI gate locally.
# Activate by running:  bash scripts/install-hooks.sh
#
# Runs the same checks GitHub Actions runs on every PR:
#   - cargo fmt --check     (workspace)
#   - cargo clippy          (workspace, -D warnings)
#   - cargo test            (workspace)
#   - frontend tsc --noEmit + eslint
#   - frontend build
#
# Set OLYMPUS_SKIP_PREPUSH=1 to bypass (emergency only — CI will still gate the PR).

set -euo pipefail

if [ "${OLYMPUS_SKIP_PREPUSH:-0}" = "1" ]; then
    echo "[pre-push] OLYMPUS_SKIP_PREPUSH=1 — skipping local CI gate."
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
step() { echo -e "\n${BOLD}▸ $1${RESET}"; }

echo -e "\n${BOLD}Olympus pre-push CI gate${RESET}"
echo "────────────────────────────────────"

FAILED=()

if git rev-parse --verify origin/main >/dev/null 2>&1; then
    CHANGED_ALL="$(git diff --name-only --diff-filter=ACMR origin/main...HEAD || true)"
else
    CHANGED_ALL="$(git diff --name-only --diff-filter=ACMR HEAD~1..HEAD || true)"
fi

CHANGED_RS="$(echo "$CHANGED_ALL" | grep -E '(^|/)Cargo\.(toml|lock)$|\.rs$' || true)"
CHANGED_FE="$(echo "$CHANGED_ALL" | grep -E '^app/public-ui/.*\.(ts|tsx|js|jsx|css|html)$|^pnpm-lock\.yaml$|^app/public-ui/package\.json$' || true)"

if [ -z "$CHANGED_RS" ] && [ -z "$CHANGED_FE" ]; then
    echo "No Rust or frontend changes relative to origin/main — skipping local CI gate."
    exit 0
fi

run_check() {
    local name="$1"
    shift
    step "$name"
    if "$@"; then
        pass "$name"
    else
        fail "$name"
        FAILED+=("$name")
    fi
}

if [ -n "$CHANGED_RS" ]; then
    # No workspace-wide `cargo fmt --check` here. GitHub CI has no fmt gate, the
    # repo has no workspace rustfmt.toml (rustfmt defaults), and a
    # whole-workspace check fails spuriously whenever the local rustfmt version
    # differs from the one main was last formatted with. Formatting of changed
    # code is handled per-staged-file by .githooks/pre-commit, so a redundant
    # push-time reformat check is omitted.

    run_check "cargo clippy --workspace -- -D warnings" \
        cargo clippy --workspace --all-targets --quiet -- -D warnings

    run_check "cargo test --workspace" \
        cargo test --workspace --quiet
fi

if [ -n "$CHANGED_FE" ]; then
    # `tsc -b` matches what CI's `pnpm build` runs (`tsc -b && vite build`).
    # `--noEmit` is looser and lets type narrowing slip past; keep symmetry
    # with .githooks/pre-commit, which had the same drift.
    run_check "frontend tsc -b" \
        bash -c 'cd app/public-ui && pnpm exec tsc -b'

    run_check "frontend eslint" \
        bash -c 'cd app/public-ui && pnpm lint'

    run_check "frontend build (vite)" \
        bash -c 'pnpm --dir app/public-ui build'
fi

echo ""
echo "────────────────────────────────────"

if [ ${#FAILED[@]} -gt 0 ]; then
    echo -e "${RED}${BOLD}Pre-push gate failed:${RESET}"
    for f in "${FAILED[@]}"; do
        echo -e "  ${RED}✗${RESET} $f"
    done
    echo ""
    echo -e "${YELLOW}Fix the above, or bypass with:${RESET}"
    echo -e "  OLYMPUS_SKIP_PREPUSH=1 git push"
    echo ""
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed — pushing.${RESET}\n"
exit 0
