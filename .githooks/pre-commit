#!/usr/bin/env bash
# pre-commit hook — hybrid Rust + frontend lint/format on staged files.
# Activate by running:  bash scripts/install-hooks.sh
#
# Behavior:
#   - Detects which staged files matter (Rust vs frontend vs neither).
#   - Auto-formats staged Rust files (cargo fmt) and runs cargo clippy.
#   - Auto-fixes staged frontend files (eslint --fix) and runs tsc --noEmit.
#   - Re-stages files the formatter touched (intentional per dev preference).
#   - If only docs / config files are staged, exits quickly with no checks.
#
# Bypass with: OLYMPUS_SKIP_PRECOMMIT=1 git commit ...
# Or:          git commit --no-verify ...

set -euo pipefail

if [ "${OLYMPUS_SKIP_PRECOMMIT:-0}" = "1" ]; then
    echo "[pre-commit] OLYMPUS_SKIP_PRECOMMIT=1 — skipping."
    exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Colors (POSIX-portable)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "  ${GREEN}✓${RESET} $1"; }
fail() { echo -e "  ${RED}✗${RESET} $1"; }
step() { echo -e "\n${BOLD}▸ $1${RESET}"; }

# Collect staged files (Added / Copied / Modified / Renamed — skip Deleted).
STAGED_ALL="$(git diff --cached --name-only --diff-filter=ACMR || true)"

if [ -z "$STAGED_ALL" ]; then
    exit 0
fi

# Partition into Rust and frontend buckets.
# Rust: *.rs anywhere, plus Cargo.toml / Cargo.lock at any depth.
STAGED_RS="$(echo "$STAGED_ALL" | grep -E '(^|/)Cargo\.(toml|lock)$|\.rs$' || true)"
# Frontend: anything under app/public-ui/ that's a JS/TS source or styles.
# Also pnpm-lock.yaml at root.
STAGED_FE="$(echo "$STAGED_ALL" | grep -E '^app/public-ui/.*\.(ts|tsx|js|jsx|css|html)$|^pnpm-lock\.yaml$|^app/public-ui/package\.json$' || true)"

if [ -z "$STAGED_RS" ] && [ -z "$STAGED_FE" ]; then
    # Docs / config / migrations / etc. — nothing for us to do.
    exit 0
fi

echo -e "${BOLD}Olympus pre-commit hook${RESET}"
echo "────────────────────────────────────"

FAILED=()

# ── Rust ────────────────────────────────────────────────────────────────────
if [ -n "$STAGED_RS" ]; then
    step "cargo fmt (auto-fix staged Rust)"
    # cargo fmt --all rewrites the whole workspace; we re-stage only what
    # was originally staged so unrelated reformats don't sneak into the
    # commit by accident.
    if cargo fmt --all; then
        # Re-stage the originally-staged Rust files in case fmt changed them.
        echo "$STAGED_RS" | xargs -r git add --
        pass "cargo fmt"
    else
        fail "cargo fmt"
        FAILED+=("cargo fmt")
    fi

    step "cargo clippy --workspace --all-targets -- -D warnings"
    if cargo clippy --workspace --all-targets --quiet -- -D warnings; then
        pass "cargo clippy"
    else
        fail "cargo clippy"
        FAILED+=("cargo clippy")
    fi
fi

# ── Frontend ────────────────────────────────────────────────────────────────
if [ -n "$STAGED_FE" ]; then
    # Filter to files inside app/public-ui (for eslint scoping).
    STAGED_FE_RELATIVE="$(echo "$STAGED_FE" | grep '^app/public-ui/' | sed 's|^app/public-ui/||' || true)"

    if [ -n "$STAGED_FE_RELATIVE" ]; then
        step "eslint --fix (auto-fix staged frontend)"
        if (cd app/public-ui && echo "$STAGED_FE_RELATIVE" | xargs -r pnpm exec eslint --fix --no-warn-ignored); then
            # Re-stage in case eslint --fix changed anything.
            echo "$STAGED_FE" | grep '^app/public-ui/' | xargs -r git add --
            pass "eslint"
        else
            fail "eslint"
            FAILED+=("eslint")
        fi
    fi

    step "tsc --noEmit (frontend type-check)"
    if (cd app/public-ui && pnpm exec tsc --noEmit); then
        pass "tsc"
    else
        fail "tsc"
        FAILED+=("tsc")
    fi
fi

echo ""
echo "────────────────────────────────────"

if [ ${#FAILED[@]} -gt 0 ]; then
    echo -e "${RED}${BOLD}Pre-commit gate failed:${RESET}"
    for f in "${FAILED[@]}"; do
        echo -e "  ${RED}✗${RESET} $f"
    done
    echo ""
    echo -e "${YELLOW}Fix the above, or bypass with:${RESET}"
    echo -e "  OLYMPUS_SKIP_PRECOMMIT=1 git commit ..."
    echo -e "  # or  git commit --no-verify ..."
    echo ""
    exit 1
fi

echo -e "${GREEN}${BOLD}All checks passed.${RESET}\n"
exit 0
