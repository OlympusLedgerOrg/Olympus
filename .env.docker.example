# Docker Compose environment.
# Copy to .env for Docker-only runs:
#   Copy-Item .env.docker.example .env
#
# Native scripts do not load this file. They load .env.local only.

POSTGRES_USER=olympus
POSTGRES_PASSWORD=change_me_use_a_strong_random_password
POSTGRES_DB=olympus

DATABASE_NAME=olympus
DATABASE_USER=olympus
DATABASE_HOST=db
DATABASE_URL=postgresql+asyncpg://olympus:change_me_use_a_strong_random_password@db:5432/olympus
PSYCOPG_URL=postgresql://olympus:change_me_use_a_strong_random_password@db:5432/olympus

OLYMPUS_ENV=development
OLYMPUS_DEV_SIGNING_KEY=true
OLYMPUS_ALLOW_PUBLIC_WRITE_REGISTRATION=0

OLYMPUS_USE_GO_SEQUENCER=true
OLYMPUS_SEQUENCER_URL=http://sequencer-go:8081
GO_SEQUENCER_URL=http://sequencer-go:8081
OLYMPUS_SEQUENCER_TOKEN=dev-sequencer-token-change-me-32b

VITE_API_BASE=http://app:8000
API_BASE_URL=http://app:8000

CORS_ORIGINS=https://yourdomain.com
TRUSTED_PROXY_IPS=[]
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
MAX_UPLOAD_BYTES=268435456

OLYMPUS_DOMAIN=olympus.yourdomain.com
OLYMPUS_PUBLIC_DOMAIN=olympus.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

OLYMPUS_REKOR_ENABLED=false
OLYMPUS_REKOR_URL=https://rekor.sigstore.dev
OLYMPUS_GUARDIAN_ENABLED=false
OLYMPUS_GUARDIAN_REGISTRY_PATH=examples/federation_registry.json
OLYMPUS_GUARDIAN_QUORUM_THRESHOLD=2
OLYMPUS_GUARDIAN_SIGN_TIMEOUT_SECONDS=5.0
