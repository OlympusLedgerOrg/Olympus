# Environment variables (never commit secrets)
.env
.env.local

# Local Docker secrets (generated by scripts/bootstrap.sh).
# Track only the README and the .gitkeep so the directory always exists.
/secrets/*
!/secrets/README.md
!/secrets/.gitkeep
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Allow TypeScript lib source directories (not Python virtualenv lib/)
!app/public-ui/src/lib/
!app/public-ui/src/lib/**
!frontend/src/lib/
!frontend/src/lib/**
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
# Virtual environments
venv/
.venv/
ENV/
env/
# IDE
.vscode/*
!.vscode/settings.json
.idea/
.claude/settings.local.json
*.swp
*.swo
*~
# OS
.DS_Store
Thumbs.db
# Test artifacts
.pytest_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/
# Circom
*.r1cs
*.wasm
*.sym
*.zkey
*.ptau
*.wtns
# Allow tracked dev ceremony placeholders
!ceremony/transcript/dev_powers_of_tau.ptau
!ceremony/transcript/dev_redaction_validity_final.zkey
# Allow circom helper libraries
!proofs/circuits/lib/
!proofs/circuits/lib/*.circom
# Node.js
node_modules/
proofs/.last-npm-hash
# Rust
verifiers/rust/target/
# Root-level Rust/maturin build artefacts (olympus_core extension)
target/
# Benchmark results
benchmarks/results/
# Local environment variables (copy .env.example to .env)
# Olympus FOIA dev SQLite database
*.db
olympus_foia.db
.olympus-wsl-*.sh
API KEY .txt
*.txt
build-log.txt
.aider*
# Runtime log files
*.log
*.err.log
logs/
.olympus-logs/
api-*.log
api-*.err.log
vite-restart.*
