# Portable PostgreSQL binaries and data (auto-downloaded by setup-windows.ps1 -UsePortablePostgres)
vendor/pgsql/
vendor/pgdata/

# Environment variables (never commit secrets)
.env
.env.local

# Postgres data directory (bind-mounted from docker-compose.yml — never commit)
/data/

# Local Docker secrets (generated by scripts/bootstrap.sh).
# Track only the README and the .gitkeep so the directory always exists.
/secrets/*
!/secrets/README.md
!/secrets/.gitkeep
