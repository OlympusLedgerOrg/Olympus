*.r1cs
*.wasm
*.sym
*.zkey
*.ptau
*.wtns
# Allow tracked dev ceremony placeholders
!ceremony/transcript/dev_powers_of_tau.ptau
!ceremony/transcript/dev_redaction_validity_final.zkey
# Allow circom helper libraries
!proofs/circuits/lib/
!proofs/circuits/lib/*.circom
# Unified-circuit vkey is gitignored until a real Groth16 setup is run for it.
# src-tauri/build.rs writes a placeholder so Tauri's bundle resources glob has
# a file to match; runtime detection refuses to start under OLYMPUS_ENV=production.
proofs/keys/verification_keys/unified_canonicalization_inclusion_root_sign_vkey.json
# Federation-quorum vkey is gitignored until its Groth16 trusted-setup ceremony
# is run (same posture as the unified circuit above). build.rs drops a
# placeholder so include_str!/bundle globs resolve; production startup refuses
# placeholders.
proofs/keys/verification_keys/federation_quorum_vkey.json
# Node.js
node_modules/
proofs/.last-npm-hash
# Rust
verifiers/rust/target/
# Root-level Rust/maturin build artefacts (olympus_core extension)
target/
# Benchmark results
benchmarks/results/
# Local environment variables (copy .env.example to .env)
# Olympus FOIA dev SQLite database
*.db
olympus_foia.db
.olympus-wsl-*.sh
