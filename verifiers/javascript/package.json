{
  "name": "@olympus/verifier",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript verifier for Olympus commitments",
  "main": "verifier.js",
  "types": "verifier.d.ts",
  "exports": {
    ".": "./verifier.js",
    "./client": "./client.js"
  },
  "typesVersions": {
    "*": {
      "client": [
