*.txt text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.command text eol=lf
# Windows batch files must use CRLF — label/goto breaks with LF-only endings
*.cmd text eol=crlf
*.bat text eol=crlf
.env* text eol=lf
# Shared git hooks are POSIX shell scripts; must keep LF on every platform
.githooks/* text eol=lf
