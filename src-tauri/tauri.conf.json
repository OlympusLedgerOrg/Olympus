{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Olympus Ledger",
  "version": "0.1.0",
  "identifier": "io.olympus.ledger",
  "build": {
    "beforeDevCommand": "pnpm --filter public-ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter public-ui build",
    "frontendDist": "../app/public-ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Olympus Ledger",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": []
  }
}
