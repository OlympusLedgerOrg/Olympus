*.ptau

# Development files
requirements-dev.txt
.pre-commit-config.yaml
.editorconfig

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Environment files (may contain secrets)
.env
.env.*
*.env
!.env.example

# Local Docker secrets — never bake into the image.
secrets/

# Temporary files
tmp/
temp/
*.tmp
