{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://olympus-protocol.org/schemas/verification_bundle.json",
  "title": "Olympus Verification Bundle",
  "description": "Self-contained bundle for offline verification of an Olympus shard commitment. Contains canonicalization provenance, the shard header, Ed25519 signature, optional RFC 3161 timestamp token, and optional Merkle inclusion proofs.",
  "type": "object",
  "required": ["bundle_version", "canonicalization", "shard_header", "signature", "pubkey"],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  },
  "properties": {
    "bundle_version": {
      "$ref": "#/$defs/semver",
      "description": "Verification bundle schema version",
      "examples": ["1.0.0"]
    },
    "schema_version": {
      "$ref": "#/$defs/semver",
      "description": "Schema version used when canonicalizing events in this bundle"
    },
    "canonicalization": {
      "type": "object",
      "description": "Canonicalization provenance for the committed artifact(s)",
      "required": ["format", "normalization_mode", "canonicalizer_versions", "fallback_reason"],
      "properties": {
        "format": { "type": "string" },
        "normalization_mode": { "type": "string" },
        "fallback_reason": { "type": ["string", "null"] },
        "canonicalizer_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "shard_header": {
      "type": "object",
      "description": "Shard header fields (header_hash is recomputed for verification)",
      "required": ["shard_id", "root_hash", "timestamp", "previous_header_hash", "header_hash"],
      "properties": {
        "shard_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^|]+$"
        },
        "root_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "timestamp": { "type": "string" },
        "previous_header_hash": { "type": "string" },
        "header_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "canonical_events": {
      "type": "array",
      "description": "Canonicalized events used to derive Merkle leaves and merkle_root",
      "items": {
        "type": "object"
      }
    },
    "leaf_hashes": {
      "type": "array",
      "description": "Hex-encoded BLAKE3 Merkle leaf hashes derived from canonical_events",
      "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "merkle_root": {
      "type": "string",
      "description": "Hex-encoded BLAKE3 Merkle root derived from leaf_hashes",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signature": {
      "type": "string",
      "description": "Hex-encoded 64-byte Ed25519 signature over header_hash",
      "pattern": "^[0-9a-f]{128}$"
    },
    "pubkey": {
      "type": "string",
      "description": "Hex-encoded 32-byte Ed25519 public key",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signed_tree_head": {
      "type": "object",
      "description": "Optional Signed Tree Head binding an epoch, tree size, and Merkle root to an Ed25519 signature",
      "required": ["epoch_id", "tree_size", "merkle_root", "timestamp", "signature", "signer_pubkey"],
      "properties": {
        "epoch_id": { "type": "integer", "minimum": 0 },
        "tree_size": { "type": "integer", "minimum": 0 },
        "merkle_root": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "timestamp": { "type": "string" },
        "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" },
        "signer_pubkey": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "previous_sth": {
      "type": "object",
      "description": "Optional previous Signed Tree Head for consistency verification",
      "required": ["epoch_id", "tree_size", "merkle_root", "timestamp", "signature", "signer_pubkey"],
      "properties": {
        "epoch_id": { "type": "integer", "minimum": 0 },
        "tree_size": { "type": "integer", "minimum": 0 },
        "merkle_root": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "timestamp": { "type": "string" },
        "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" },
        "signer_pubkey": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "epoch_record": {
      "type": "object",
      "description": "Optional epoch chaining record for tamper-evident replication validation",
      "required": ["epoch_index", "previous_epoch_head", "merkle_root", "metadata_hash", "epoch_head"],
      "properties": {
        "epoch_index": { "type": "integer", "minimum": 0 },
        "previous_epoch_head": { "type": "string", "pattern": "^[0-9a-f]{64}$|^$" },
        "merkle_root": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "metadata_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "epoch_head": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "consistency_proof": {
      "type": "object",
      "description": "Optional Merkle consistency proof linking previous_sth to signed_tree_head",
      "required": ["old_tree_size", "new_tree_size", "proof_nodes"],
      "properties": {
        "old_tree_size": { "type": "integer", "minimum": 0 },
        "new_tree_size": { "type": "integer", "minimum": 0 },
        "proof_nodes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "timestamp_token": {
      "type": "object",
      "description": "Optional RFC 3161 timestamp token for the header hash",
      "required": ["hash_hex", "tsa_url", "tst_hex", "timestamp", "tsa_cert_fingerprint"],
      "properties": {
        "hash_hex": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "tsa_url": { "type": "string", "format": "uri" },
        "tst_hex": { "type": "string" },
        "timestamp": { "type": "string" },
        "tsa_cert_fingerprint": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "merkle_proofs": {
      "type": "array",
      "description": "Optional Merkle inclusion proofs anchored to the shard root",
      "items": {
        "type": "object",
        "required": ["leaf_hash", "leaf_index", "siblings", "root_hash"],
        "properties": {
          "leaf_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "leaf_index": { "type": "integer", "minimum": 0 },
          "siblings": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": [
                { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                { "type": "boolean" }
              ]
            }
          },
          "root_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "smt_proof": {
      "type": "object",
      "description": "Optional sparse Merkle tree proof payload emitted by protocol.verification_bundle.create_verification_bundle"
    }
  }
}
