# Olympus Environment Variables
# Copy this file to .env and update the values for your local environment

# Database Configuration
# PostgreSQL connection string for production API
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://olympus:olympus@localhost:5432/olympus

# Test Database Configuration
# PostgreSQL connection string for running tests
# Can be the same as DATABASE_URL or a separate test database
TEST_DATABASE_URL=postgresql://olympus:olympus@localhost:5432/olympus

# UI Configuration
# Base URL for the API when running the UI locally
UI_API_BASE=http://127.0.0.1:8000

# Debug UI features (set to "true" to enable debug console and proof explorer)
OLYMPUS_DEBUG_UI=false

# API Configuration
# Port for the API server (default: 8000)
# API_PORT=8000

# UI Port (default: 8080)
# UI_PORT=8080

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Storage Configuration
# S3 bucket name for blob storage (optional, not used in v1.0)
# S3_BUCKET_NAME=olympus-blobs

# AWS Region for S3 (optional, not used in v1.0)
# AWS_REGION=us-east-1

# RFC3161 Timestamp Server (optional, for timestamping)
# RFC3161_URL=http://timestamp.digicert.com

# Development Settings
# Set to "true" to enable development mode features
# DEV_MODE=false
