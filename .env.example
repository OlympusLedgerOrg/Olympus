# Local PostgreSQL Database Credentials
POSTGRES_USER=olympus
POSTGRES_PASSWORD=olympus
POSTGRES_DB=olympus

# Demo API Key for Local Development
# The raw key is "demo-key"
OLYMPUS_API_KEYS_JSON=[{"key_hash":"84d53ce2f18ae4856edfe631810f984b8c78bf3c0e136bac89e45642c5c85b37","key_id":"demo-key","scopes":["ingest","commit","verify"],"expires_at":"2099-01-01T00:00:00Z"}]

# Dev-only signing key generation
OLYMPUS_DEV_SIGNING_KEY=true

# Database URL for application connection
DATABASE_URL=postgresql://olympus:olympus@db:5432/olympus

# UI API Base URL
UI_API_BASE=http://app:8000
