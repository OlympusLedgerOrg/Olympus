# Olympus local development environment.
# Copy to .env for local work only. Do not ship .env, .env.local, or secrets/.
# Generate fresh production secrets with a secret manager or CSPRNG before any
# shared build.

# Runtime environment. Production enables fail-closed startup checks.
OLYMPUS_ENV=development

# Desktop API bind port. Leave unset to use the default.
# OLYMPUS_API_PORT=8001

# External PostgreSQL is optional for local development; when unset, the desktop
# app starts its embedded PostgreSQL instance. Uncomment and replace this local
# dummy value only when you intentionally want to use an external database.
# DATABASE_URL=postgresql://olympus:example_password_do_not_use@localhost:5432/olympus

# Operator admin/recovery key. Required in production.
# Generate with: openssl rand -hex 32
OLYMPUS_ADMIN_KEY=

# Persistent Baby Jubjub authority key. Required in production.
# Generate with the first-run modal or a 32-byte CSPRNG value, then keep stable.
OLYMPUS_BJJ_AUTHORITY_KEY=

# Persistent Ed25519 signing key for ingest/redaction bundles.
# Required in production. Must be 32-byte hex.
OLYMPUS_INGEST_SIGNING_KEY=

# Independent object-redaction blinding secret.
# Required in production. Must be 32-byte hex.
OLYMPUS_REDACTION_BLIND_SECRET=

# Dev-only signing shortcut. Production startup refuses this when set to true
# or to a hex key; use OLYMPUS_INGEST_SIGNING_KEY instead.
OLYMPUS_DEV_SIGNING_KEY=false

# Public unauthenticated write registration is local-dev only.
# Production startup refuses OLYMPUS_ALLOW_PUBLIC_WRITE_REGISTRATION=1.
OLYMPUS_ALLOW_PUBLIC_WRITE_REGISTRATION=0

# Dev-only key-generation helper route gate. Requires a build with the
# dev-signing-route feature and is refused in production when enabled.
OLYMPUS_ALLOW_DEV_SIGNING_KEY_BOOTSTRAP=0

# Dev-only recovery-token echo. Refused in production when enabled.
OLYMPUS_RETURN_RECOVERY_TOKEN=0

# Optional proof-artifact override. Production must point at populated real
# Groth16 artifacts, not placeholders.
# OLYMPUS_PROOFS_DIR=C:\path\to\proofs\keys

# Optional trusted issuers rotation JSON.
# OLYMPUS_BJJ_TRUSTED_ISSUERS_JSON=[]

# Optional federation.
OLYMPUS_FEDERATION_ENABLED=0
OLYMPUS_FEDERATION_SYNC_INTERVAL=60
OLYMPUS_FEDERATION_AUTO_BLOCK=1

# Optional anchoring backends.
OLYMPUS_ANCHOR_RFC3161_URL=
OLYMPUS_ANCHOR_REKOR_URL=
OLYMPUS_ANCHOR_REKOR_PUBKEY_PEM=
OLYMPUS_ANCHOR_OTS_CALENDARS=
OLYMPUS_ANCHOR_INTERVAL_SECS=300
