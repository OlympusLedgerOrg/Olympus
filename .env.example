# Local PostgreSQL Database Credentials
POSTGRES_USER=olympus_user
POSTGRES_PASSWORD=change_me_use_a_strong_random_password
POSTGRES_DB=olympus

# API Keys JSON (see docs for format)
# The key_hash field must be a BLAKE3 hex digest of your raw API key.
OLYMPUS_API_KEYS_JSON=[{"key_hash":"<blake3-hex-of-your-key>","key_id":"my-key","scopes":["read","write"],"expires_at":"2099-01-01T00:00:00Z"}]

# Dev-only signing key generation (set to false in production)
# WARNING: If OLYMPUS_DEV_SIGNING_KEY=true and you restart the API without a persistent
# OLYMPUS_INGEST_SIGNING_KEY, a new signing key will be auto-generated on each restart.
# This breaks signature verification for previously signed shard headers.
# For production: set OLYMPUS_DEV_SIGNING_KEY=false and provide an explicit signing key.
OLYMPUS_DEV_SIGNING_KEY=false

# Database connection components (used with Docker secrets for password)
DATABASE_NAME=olympus
DATABASE_USER=olympus_user
DATABASE_HOST=db

# Database URL for application connection (use ?sslmode=require in production)
# Keep credentials in sync with POSTGRES_* values above.
# Use 'localhost' for local development; replace with 'db' when using Docker Compose networking.
DATABASE_URL=postgresql+asyncpg://olympus_user:change_me_use_a_strong_random_password@localhost:5432/olympus
PSYCOPG_URL=postgresql://olympus_user:change_me_use_a_strong_random_password@localhost:5432/olympus

# UI API Base URL
UI_API_BASE=http://app:8000

# Oracle AI (Claude) — required for /oracle/refine and /oracle/appeal
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Debug UI is now always enabled. Use OLYMPUS_DEBUG_CONSOLE_PASSWORD to protect it.
# OLYMPUS_DEBUG_UI=true  # No longer required

# Optional: protect the debug console with HTTP Basic Auth.
# Set a strong random string here if the UI is accessible over a network.
# REQUIRED when OLYMPUS_ENV=production — leave blank only for local-only development.
OLYMPUS_DEBUG_CONSOLE_PASSWORD=

# Oracle rate limiting (per IP, sliding window)
ORACLE_RATE_LIMIT_REQUESTS=10
ORACLE_RATE_LIMIT_WINDOW_SECONDS=60

# Trusted proxy IPs/CIDRs for X-Forwarded-For parsing (comma-separated).
# Only peers in this list may set X-Forwarded-For to influence client IP resolution.
# Do NOT set a global CIDR (0.0.0.0/0 or ::/0); Olympus treats this as insecure and
# ignores X-Forwarded-For to prevent client IP spoofing.
TRUSTED_PROXY_IPS=  # e.g. 10.0.0.1,172.16.0.0/12

# CORS allowed origins (comma-separated). Must be explicitly configured in production.
# Do NOT use wildcard origins when sending credentials; configure explicit origins only.
CORS_ORIGINS=https://yourdomain.com  # Comma-separated allowed origins

# Rate limit backend: "memory" (default, per-process) or "redis" (shared).
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=  # Required when RATE_LIMIT_BACKEND=redis

# Maximum upload file size in bytes (default 256 MB)
MAX_UPLOAD_BYTES=268435456  # 256 MB

# TLS / Traefik configuration
OLYMPUS_DOMAIN=olympus.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Generate with: python -m olympus.tools.generate_api_key --scope read,write --expires 2026-12-31
# OLYMPUS_API_KEYS_JSON=

# Connection pool maximum size (default 20)
OLYMPUS_POOL_MAX_SIZE=20

# ──────────────────────────────────────────────────────────────────────────────
# Trigger Gate Secret (RT-M3)
# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED in production. Mixes a deployment-specific secret into the SMT
# trigger gate value so it is not derivable from source code alone.
# An attacker with DB access cannot bypass trigger protection without this secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OLYMPUS_NODE_REHASH_GATE_SECRET=

# Poseidon redaction circuit tree depth (default 4 → 16 leaves; max 8 → 256 leaves)
OLYMPUS_POSEIDON_TREE_DEPTH=4

# Structured logging format: "text" (default) or "json" (recommended for production)
OLYMPUS_LOG_FORMAT=text

# ──────────────────────────────────────────────────────────────────────────────
# Sigstore Rekor Anchoring (C-02 Phase 1)
# ──────────────────────────────────────────────────────────────────────────────
# Enable asynchronous anchoring of shard headers to Sigstore Rekor transparency log.
# This provides external tamper-evidence without requiring live Guardian nodes.
OLYMPUS_REKOR_ENABLED=false
# Rekor API base URL (default: https://rekor.sigstore.dev)
OLYMPUS_REKOR_URL=https://rekor.sigstore.dev

# ──────────────────────────────────────────────────────────────────────────────
# Guardian Replication (C-02 Phase 1)
# ──────────────────────────────────────────────────────────────────────────────
# Enable Guardian node quorum signing for shard headers.
# When enabled, shard headers require 2-of-3 Guardian signatures before commit.
OLYMPUS_GUARDIAN_ENABLED=false
# Path to federation registry JSON file
OLYMPUS_GUARDIAN_REGISTRY_PATH=examples/federation_registry.json
# Quorum threshold (number of signatures required)
OLYMPUS_GUARDIAN_QUORUM_THRESHOLD=2
# Timeout for collecting Guardian signatures (seconds)
OLYMPUS_GUARDIAN_SIGN_TIMEOUT_SECONDS=5.0

# ──────────────────────────────────────────────────────────────────────────────
# Go Sequencer Write Path (A-01)
# ──────────────────────────────────────────────────────────────────────────────
# When enabled, Python routes all write operations through the Go sequencer
# instead of directly to storage/postgres.py. The Go sequencer delegates
# all SMT operations to the Rust CD-HS-ST service.
#
# To run with Docker Compose: docker compose --profile sequencer up -d
#
# OLYMPUS_USE_GO_SEQUENCER: Enable Go sequencer routing (default: false)
#   Set to "true", "1", "yes", or "on" to enable.
OLYMPUS_USE_GO_SEQUENCER=false

# OLYMPUS_SEQUENCER_URL: Go sequencer HTTP base URL
#   Default: http://localhost:8081 (or http://sequencer-go:8081 in Docker)
OLYMPUS_SEQUENCER_URL=http://localhost:8081

# OLYMPUS_SEQUENCER_TOKEN: Shared secret for X-Sequencer-Token header authentication
#   Generate with: openssl rand -hex 32
#   REQUIRED when OLYMPUS_USE_GO_SEQUENCER=true
OLYMPUS_SEQUENCER_TOKEN=

# OLYMPUS_SEQUENCER_SIGNING_KEY: Ed25519 signing key for Rust CD-HS-ST service
#   If not set, falls back to OLYMPUS_INGEST_SIGNING_KEY for consistency.
#   Use a separate key only if you need different signing authorities for
#   Python direct writes vs Go sequencer writes.
# OLYMPUS_SEQUENCER_SIGNING_KEY=

# OLYMPUS_SEQUENCER_TIMEOUT_SECONDS: HTTP request timeout for sequencer calls
#   Default: 30 seconds
OLYMPUS_SEQUENCER_TIMEOUT_SECONDS=30

# OLYMPUS_SEQUENCER_MAX_BATCH_SIZE: Maximum records per /v1/queue-leaves request
#   Default: 1000. Requests exceeding this limit return HTTP 400.
OLYMPUS_SEQUENCER_MAX_BATCH_SIZE=1000
