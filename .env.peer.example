# ─────────────────────────────────────────────────────────────────────────────
# Olympus peer node config — for a buddy's Mac connecting to the host's DB
#
# SECURITY MODEL
#   Postgres is NEVER directly reachable from the network.
#   The buddy connects via an SSH tunnel over Tailscale, which makes the
#   host's Postgres appear as localhost:5433 on the buddy's machine.
#
# SETUP (Mac):
#   1. Clone the repo
#   2. cp .env.peer.example .env
#   3. Fill in DB_PASSWORD below — copy from host's secrets/db_password file
#   4. python -m venv .venv && source .venv/bin/activate
#   5. pip install -r requirements.txt
#   6. # Apply firewall rules on this Mac (Tailscale subnet only):
#      sudo bash scripts/firewall-peer-mac.sh
#   7. # Open SSH tunnel to host (keep this terminal open):
#      ssh -N -L 5433:localhost:5433 <windows-username>@<host-tailscale-ip>
#   8. # In another terminal, start the node:
#      uvicorn api.main:app --host 0.0.0.0 --port 8000
#
# ── Tailscale setup (both machines):
#      https://tailscale.com/download
#      tailscale up
#      tailscale ip   ← run on the Windows host to get the 100.x.x.x address
#
# ── Windows host must have OpenSSH Server enabled:
#      Settings → Apps → Optional features → Add "OpenSSH Server"
#      Set-Service sshd -StartupType Automatic; Start-Service sshd
#      # Run the firewall script on the host too:
#      powershell -ExecutionPolicy Bypass -File scripts\firewall-peer-windows.ps1
# ─────────────────────────────────────────────────────────────────────────────

# ── Point at the host's Postgres via SSH tunnel ───────────────────────────────
# Postgres is never directly reachable from the network.
# Open an SSH tunnel first (keep that terminal open the whole session):
#
#   ssh -N -L 5433:localhost:5433 <your-windows-username>@<host-tailscale-ip>
#
# Once the tunnel is up, localhost:5433 on THIS Mac is the host's Postgres.
DATABASE_URL=postgresql+asyncpg://olympus:DB_PASSWORD@localhost:5433/olympus
PSYCOPG_URL=postgresql://olympus:DB_PASSWORD@localhost:5433/olympus

# ── Must match the host's OLYMPUS_ENV so startup guards agree ────────────────
OLYMPUS_ENV=development

# ── Skip dev signing key — use the host's persistent key instead ─────────────
# Copy OLYMPUS_INGEST_SIGNING_KEY value from the host's .env here so both
# nodes sign with the same key and historical roots stay verifiable.
OLYMPUS_INGEST_SIGNING_KEY=
OLYMPUS_DEV_SIGNING_KEY=false

# ── CORS: allow the peer's own origin ────────────────────────────────────────
# Set to wherever the peer's UI will be served from, or * for local testing.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Sequencer: point at the host if using Go sequencer ───────────────────────
# Leave false unless the host has OLYMPUS_USE_GO_SEQUENCER=true.
OLYMPUS_USE_GO_SEQUENCER=false
# If true, point at host:
# OLYMPUS_SEQUENCER_URL=http://YOUR_HOST_IP:8081
# OLYMPUS_SEQUENCER_TOKEN=   # same token as host

# ── These can stay as-is ─────────────────────────────────────────────────────
OLYMPUS_LOG_FORMAT=text
RATE_LIMIT_BACKEND=memory
MAX_UPLOAD_BYTES=268435456
OLYMPUS_GUARDIAN_ENABLED=false
OLYMPUS_REKOR_ENABLED=false
