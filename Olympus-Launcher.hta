<!doctype html>
<html>
<head>
  <meta http-equiv="x-ua-compatible" content="IE=edge">
  <title>Olympus Local App</title>
  <hta:application
    id="OlympusLauncher"
    applicationname="Olympus Local App"
    border="thin"
    caption="yes"
    maximizebutton="no"
    minimizebutton="yes"
    scroll="no"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="maximize"
  />
  <style>
    html,
    body {
      width: 100%;
      height: 100%;
      margin: 0;
      overflow: hidden;
      background: #080d12;
      color: #edf7f4;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    .shell {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      background: #080d12;
    }

    .hero {
      width: 100vw;
      height: 100vh;
      object-fit: cover;
      display: block;
    }

    .fallback {
      width: 100vw;
      height: 100vh;
      display: none;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #09121a 0%, #10242a 54%, #231d11 100%);
      color: #edf7f4;
      font-size: 44px;
      font-weight: 700;
      letter-spacing: 4px;
    }

    .status {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 72px;
      padding: 12px 26px 0;
      box-sizing: border-box;
      background: rgba(7, 16, 21, 0.88);
      border-top: 1px solid rgba(116, 221, 196, 0.28);
    }

    .line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      font-size: 14px;
      color: #b8cbc7;
      margin-bottom: 10px;
    }

    .url {
      color: #80e5ca;
      font-weight: 600;
    }

    .track {
      position: relative;
      width: 100%;
      height: 10px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.12);
    }

    .bar {
      position: absolute;
      top: 0;
      left: -35%;
      width: 35%;
      height: 10px;
      border-radius: 999px;
      background: linear-gradient(90deg, #47d7ff, #66f0c2, #f4c95d);
    }
  </style>
</head>
<body>
  <div class="shell">
    <img id="hero" class="hero" alt="Olympus loading" src="app/public-ui/loading.png">
    <div id="fallback" class="fallback">OLYMPUS</div>
    <div class="status">
      <div class="line">
        <span id="statusText">Starting native Olympus services...</span>
        <span class="url">UI http://127.0.0.1:5173 // API http://127.0.0.1:8000</span>
      </div>
      <div class="track"><div id="bar" class="bar"></div></div>
    </div>
  </div>

  <script language="javascript">
    var targetUrl = "http://127.0.0.1:5173";
    var apiUrl = "http://127.0.0.1:8000/health";
    var startedAt = new Date().getTime();
    var minimumDisplayMs = 7000;

    try {
      window.moveTo(0, 0);
      window.resizeTo(screen.availWidth, screen.availHeight);
    } catch (e) {}

    document.getElementById("hero").onerror = function () {
      this.style.display = "none";
      document.getElementById("fallback").style.display = "flex";
    };

    var pos = -35;
    window.setInterval(function () {
      pos += 2;
      if (pos > 100) pos = -35;
      document.getElementById("bar").style.left = pos + "%";
    }, 35);

    function setStatus(text) {
      try {
        document.getElementById("statusText").innerText = text;
      } catch (e) {}
    }

    function checkUrl(url, onReady, onPending) {
      try {
        var req = null;
        if (window.XMLHttpRequest) {
          req = new XMLHttpRequest();
        } else {
          req = new ActiveXObject("Microsoft.XMLHTTP");
        }

        req.onreadystatechange = function () {
          if (req.readyState !== 4) return;
          if (req.status >= 200 && req.status < 500) {
            onReady();
          } else {
            onPending();
          }
        };

        req.open("GET", url + (url.indexOf("?") >= 0 ? "&" : "?") + "olympusLauncherReady=" + new Date().getTime(), true);
        req.send();
      } catch (e) {
        onPending();
      }
    }

    function tryOpenApp() {
      setStatus("Waiting for API...");
      checkUrl(apiUrl, function () {
        setStatus("Waiting for UX...");
        checkUrl(targetUrl + "/", function () {
          setStatus("Opening Olympus...");
          openAppAndCloseSplash();
        }, function () {
          window.setTimeout(tryOpenApp, 1000);
        });
      }, function () {
        window.setTimeout(tryOpenApp, 1000);
      });
    }

    window.setTimeout(tryOpenApp, 1000);

    function openAppAndCloseSplash() {
      var elapsed = new Date().getTime() - startedAt;
      var remaining = minimumDisplayMs - elapsed;
      if (remaining > 0) {
        setStatus("Olympus is ready...");
        window.setTimeout(openAppAndCloseSplash, remaining);
        return;
      }

      try {
        var shell = new ActiveXObject("WScript.Shell");
        shell.Run('cmd /c start "" "' + targetUrl + '"', 0, false);
      } catch (e) {
        try {
          window.open(targetUrl, "_blank");
        } catch (ignored) {}
      }

      window.setTimeout(function () {
        window.close();
      }, 1500);
    }
  </script>
</body>
</html>
